#!/usr/bin/env bash
# Generates various IDs.
if [ "$1" = "password" ]; then
	id=$(tr -dc '0-9a-f' < /dev/urandom | head -c 32)
elif [ "$1" = "uuid" ]; then
	id=$(uuidgen)
elif [ "$1" = "totp" ]; then
	# Useful for generating 2fa codes provided an original time-based key (e.g. from Slack).
	id=$(oathtool -b --totp "$2")
fi
echo "$id"
clip "$id"
