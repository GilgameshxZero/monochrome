#!/usr/bin/env bash
# Generates various IDs.
if [ "$1" = "password" ]; then
	id=$(tr -dc '0-9a-f' < /dev/urandom | head -c 32)
elif [ "$1" = "uuid" ]; then
	id=$(uuidgen)
elif [ "$1" = "totp" ]; then
	id=$(oathtool -b --totp "$2")
fi
echo "$id"
qdbus6 org.kde.klipper /klipper setClipboardContents "$id"
