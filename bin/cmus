#!/usr/bin/env bash
if ! pgrep -x cmus > /dev/null; then
	# set status off not working; minor issue.
	tmux new -d -s cmus \; set status off \;
	tmux send -t cmus "cd ~/main.syncthing/prototype && /usr/bin/cmus" ENTER
fi
if [[ ! -v TMUX ]]; then
	tmux a -t cmus
else
	tmux detach -E "tmux a -t cmus"
fi
