{
	// Base code/codium settings.
	"breadcrumbs.enabled": false,

	"chat.editor.fontSize": 19,
	"chat.commandCenter.enabled": false,

	"comments.visible": false,

	"debug.onTaskErrors": "abort",
	"debug.console.fontSize": 20,
	"debug.openDebug": "neverOpen",
	"debug.internalConsoleOptions": "openOnSessionStart",
	"debug.console.closeOnEnd": false,
	"debug.terminal.clearBeforeReusing": true,

	"diffEditor.ignoreTrimWhitespace": false,

	"editor.autoClosingBrackets": "languageDefined",
	"editor.rulers": [60, 80, 120],
	"editor.inlineSuggest.enabled": true,
	"editor.insertSpaces": false,
	"editor.tabSize": 2,
	"editor.fastScrollSensitivity": 10,
	"editor.folding": false,
	"editor.unicodeHighlight.nonBasicASCII": false,
	"editor.wordWrap": "on",
	"editor.wordWrapColumn": 80,
	"editor.minimap.enabled": false,
	"editor.experimental.asyncTokenization": true,
	"editor.stickyScroll.enabled": false,
	"editor.glyphMargin": false,
	// "editor.tokenColorCustomizations": {},
	"editor.accessibilitySupport": "off",
	"editor.cursorBlinking": "solid",
	"editor.cursorSurroundingLines": 2,
	// "editor.letterSpacing": -0.33,
	"editor.suggest.showWords": false,
	"editor.inlayHints.enabled": "off",
	"editor.wrappingIndent": "indent",
	"editor.fontSize": 19,
	"editor.inertialScroll": false,
	"editor.mouseWheelScrollSensitivity": 1.5,
	"editor.quickSuggestions": {
		"other": false,
		"comments": "off",
		"strings": "off"
	},
	"editor.lightbulb.enabled": "off",
	"editor.pasteAs.showPasteSelector": "never",
	"editor.colorDecorators": false,
	// Disable all color and syntax highlights. The second line is needed in case of external (?) language servers e.g. `clangd`.
	"editor.maxTokenizationLineLength": 0,
	"editor.tokenColorCustomizations": {
		"[Default High Contrast]": {
			"comments": "#FF0000",
			"functions": "#FF0000",
			"keywords": "#FF0000",
			"numbers": "#FF0000",
			"strings": "#FF0000",
			"types": "#FF0000",
			"variables": "#FF0000",
			"textMateRules": [
				{
					"scope": "constant",
					"settings": {
						"foreground": "#FF0000"
					}
				},
				{
					"scope": "emphasis",
					"settings": {
						"foreground": "#FF0000"
					}
				},
				{
					"scope": "entity",
					"settings": {
						"foreground": "#FF0000"
					}
				},
				{
					"scope": "meta",
					"settings": {
						"foreground": "#FF0000"
					}
				},
				{
					"scope": "support",
					"settings": {
						"foreground": "#FF0000"
					}
				},
				{
					"scope": "invalid",
					"settings": {
						"foreground": "#FFFF00"
					}
				},
				{
					"scope": "keyword",
					"settings": {
						"foreground": "#FF0000"
					}
				},
				{
					"scope": "punctuation",
					"settings": {
						"foreground": "#FF0000"
					}
				},
				{
					"scope": "string",
					"settings": {
						"foreground": "#FF0000"
					}
				},
				{
					"scope": "markup",
					"settings": {
						"foreground": "#FF0000"
					}
				},
				{
					"scope": "variable",
					"settings": {
						"foreground": "#FF0000"
					}
				}
			]
		}
	},
	"editor.semanticHighlighting.enabled": false,
	"editor.selectionHighlight": false,
	"editor.cursorStyle": "block",
	"editor.lineNumbers": "off",
	// Undocumented for 0-width gutter.
	"editor.lineDecorationsWidth": 0,
	"editor.occurrencesHighlight": "off",
	"editor.hover.showLongLineWarning": false,

	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.sortOrder": "mixed",
	"explorer.decorations.colors": false,

	"extensions.ignoreRecommendations": true,
	"extensions.autoUpdate": false,
	"extensions.experimental.affinity": {
		"ms-toolsai.jupyter": 2,
		"ms-python.python": 2
	},
	"extensions.autoCheckUpdates": false,

	"files.eol": "\n",
	"files.exclude": {
		"**/.DS_Store": false,
		"**/.git": false,
		"**/.hg": false,
		"**/.svn": false
	},
	"files.insertFinalNewline": true,

	"git.enableSmartCommit": true,
	"git.openRepositoryInParentFolders": "always",
	"git.ignoreMissingGitWarning": true,
	"git.decorations.enabled": false,

	"html.format.indentInnerHtml": true,
	"html.format.wrapLineLength": 60,

	"markdown.preview.breaks": true,
	"markdown.copyFiles.destination": {
		"**/*": "${documentDirName}/${documentFileName}.asset/${unixTime}.${fileName}"
	},
	"markdown.preview.fontSize": 16,
	"markdown.preview.lineHeight": 1.5,
	"markdown.preview.scrollPreviewWithEditor": true,

	// Most markdown files should be edited with the `silver` CSS.
	"markdown.styles": [".vscode/default.css"],

	"search.quickOpen.includeHistory": false,
	"search.exclude": {
		"**/.venv": true
	},

	"security.workspace.trust.untrustedFiles": "open",

	"task.problemMatchers.neverPrompt": {
		"shell": true
	},

	"terminal.integrated.fontSize": 19,
	// Closes terminals faster (on Windows); faster tasks/builds.
	"terminal.integrated.profiles.windows": {
		"Command Prompt": {
			"path": [
				// Need the first line in case {windir} is not defined (e.g. on codium).
				"C:\\Windows\\System32\\cmd.exe",
				"${env:windir}\\System32\\cmd.exe",
				"${env:windir}\\Sysnative\\cmd.exe"
			],
			"icon": "terminal-cmd"
		},
		"PowerShell": {
			"source": "PowerShell",
			"icon": "terminal-powershell"
		},
		"Git Bash": {
			"source": "Git Bash"
		}
	},
	"terminal.integrated.profiles.linux": {
		"bash": {
			"path": "bash",
			"icon": "terminal-bash",
			// Necessary for loading `~/.bashrc` properly.
			"args": ["-i"]
		}
	},
	"terminal.integrated.profiles.osx": {
		"zsh": {
			"path": "zsh",
			"icon": "terminal-bash",
			// Necessary for loading `~/.zshrc` properly. TODO.
			"args": ["-i"]
		}
	},
	"terminal.integrated.defaultProfile.windows": "Command Prompt",
	"terminal.integrated.defaultProfile.linux": "bash",
	"terminal.integrated.enableMultiLinePasteWarning": "never",
	"terminal.integrated.defaultProfile.osx": "zsh",
	"terminal.integrated.gpuAcceleration": "on",
	"terminal.integrated.confirmOnKill": "never",
	"terminal.integrated.rightClickBehavior": "default",
	"terminal.integrated.commandsToSkipShell": [
		"workbench.action.closeActiveEditor",
		"workbench.action.nextEditor",
		"workbench.action.previousEditor",
		"workbench.action.openEditorAtIndex1",
		"workbench.action.openEditorAtIndex2",
		"workbench.action.openEditorAtIndex3",
		"workbench.action.openEditorAtIndex4",
		"workbench.action.openEditorAtIndex5",
		"workbench.action.openEditorAtIndex6",
		"workbench.action.openEditorAtIndex7",
		"workbench.action.openEditorAtIndex8",
		"workbench.action.openEditorAtIndex9",
		"workbench.action.lastEditorInGroup",
		"workbench.action.moveEditorLeftInGroup",
		"workbench.action.moveEditorRightInGroup"
	],
	"terminal.integrated.scrollback": 8192,
	"terminal.integrated.ignoreBracketedPasteMode": true,
	"terminal.integrated.persistentSessionScrollback": 1024,
	"terminal.integrated.showExitAlert": false,
	"terminal.integrated.stickyScroll.enabled": false,
	"terminal.integrated.defaultLocation": "editor",
	"terminal.integrated.minimumContrastRatio": 21,
	"terminal.integrated.tabStopWidth": 2,
	"terminal.integrated.shellIntegration.decorationsEnabled": "never",
	"terminal.integrated.shellIntegration.quickFixEnabled": false,

	"timeline.pageOnScroll": true,

	"update.showReleaseNotes": false,
	"update.mode": "manual",

	"window.autoDetectColorScheme": true,
	"window.commandCenter": false,
	"window.enableMenuBarMnemonics": false,
	"window.restoreWindows": "none",
	"window.restoreFullscreen": true,
	"window.customTitleBarVisibility": "windowed",
	"window.menuBarVisibility": "compact",
	"window.newWindowProfile": "Default",
	"window.density.editorTabHeight": "compact",

