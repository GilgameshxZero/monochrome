		"include": ["C:/Android/platforms/android-34/*.jar", "lib/*.jar"]
	},
	"java.inlayHints.parameterNames.enabled": "none",

	"jupyter.askForKernelRestart": false,
	"jupyter.interactiveWindow.textEditor.cellFolding": false,

	"markdown.extension.print.absoluteImgPath": false,
	"markdown.extension.toc.unorderedList.marker": "*",
	"markdown.extension.tableFormatter.enabled": false,
	"markdown.extension.toc.updateOnSave": false,
	"markdown.extension.syntax.plainTheme": true,
	"markdown.extension.list.indentationSize": "inherit",
	"markdown.extension.print.includeVscodeStylesheets": false,
	"markdown.extension.print.pureHtml": true,

	"notebook.cellToolbarLocation": {
		"default": "hidden",
		"jupyter-notebook": "hidden"
	},
	"notebook.output.wordWrap": true,
	"notebook.editorOptionsCustomizations": {
		"editor.tabSize": 2,
		"editor.indentSize": 2,
		"editor.insertSpaces": false
	},
	"notebook.confirmDeleteRunningCell": false,
	"notebook.formatOnSave.enabled": true,
	"notebook.output.textLineLimit": 10,
	"notebook.output.scrolling": true,
	"notebook.globalToolbar": false,
	"notebook.showCellStatusBar": "hidden",

	"prettier.useTabs": true,
	"prettier.trailingComma": "none",

	"python.createEnvironment.trigger": "off",

	"redhat.telemetry.enabled": false,

	"remote.SSH.remotePlatform": {
		"gilgamesh-31": "linux",
		"gilgamesh-40": "linux",
		"gilgamesh-42": "windows",
		"gilgamesh-43": "macos",
		"gilgamesh-44": "linux",
		"gilgamesh-45": "linux",
		"gilgamesh-46": "windows",
		"gilgamesh-47": "linux",
		"gilgamesh-49": "windows",
		"gilgamesh-51": "linux"
	},
	// Sometimes necessary for `git` to function on Windows remotes.
	// "remote.SSH.enableAgentForwarding": false,
	"remote.autoForwardPorts": false,

	"xml.format.maxLineWidth": 80,
	"xml.server.preferBinary": true,

	"yapf.args": [
		"--style",
		"{based_on_style: pep8, indent_width: 2, continuation_indent_width: 2, column_limit: 59, use_tabs: True, continuation_align_style: FIXED}"
	],

	// Formatters.
	"[css]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[markdown]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.rulers": [],
		// For some reason, "advanced" is broken with Latin Modern Roman without GPU acceleration.
		"editor.wrappingStrategy": "advanced",
		"editor.wordWrap": "on",
		"editor.cursorStyle": "line"
	},
	"[cpp]": {
		"editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
	},
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[json]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[python]": {
		"editor.defaultFormatter": "eeyore.yapf",
		"editor.insertSpaces": false,
		"editor.tabSize": 2
	},
	"[xml]": {
		"editor.defaultFormatter": "redhat.vscode-xml"
	},
	"[java]": {
		"editor.defaultFormatter": "redhat.java"
	},
	"[typescript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},

	// VSCode-specific settings.
	"inlineChat.lineNaturalLanguageHint": false,

	"liveshare.notebooks.allowGuestExecuteCells": true,

	"remote.SSH.externalSSH_ASKPASS": true,
	"remote.SSH.enableRemoteCommand": true,
	// Fixes Agent forwarding, specifically on Windows -> Linux.
	"remote.SSH.useExecServer": false,
	"remote.SSH.lockfilesInTmp": true,
	"remote.SSH.localServerDownload": "always",

	"settingsSync.ignoredSettings": [
		"workbench.colorTheme",
		"-C_Cpp.intelliSenseMemoryLimit",
		"-C_Cpp.intelliSenseCacheSize"
	],

	"C_Cpp.formatting": "clangFormat",
	"C_Cpp.dimInactiveRegions": true,
