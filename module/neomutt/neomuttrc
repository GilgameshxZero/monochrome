# Use this file with
# `source ~/main.syncthing/monochrome/module/neomutt/neomuttrc`.
# This file automatically sources the relevant passwords.
source ~/main.syncthing/monochrome/module/neomutt/neomuttrc.password

set imap_user="yangawesome@gmail.com"
set folder="imaps://imap.gmail.com"
set spoolfile=+INBOX
set record="+[Gmail]/Sent Mail"
set postponed="+[Gmail]/Drafts"
set trash = "+[Gmail]/Bin"

set imap_authenticators = "oauthbearer:xoauth2"
set imap_oauth_refresh_command = "/usr/share/neomutt/oauth2/mutt_oauth2.py ~/main.syncthing/monochrome/module/neomutt/yangawesome_gmail.com.password.token --decryption-pipe cat --encryption-pipe cat"

set realname="Yang Yan"
set from="yang@gilgamesh.cc"
unset ssl_force_tls
set smtp_url="smtp://yang@gilgamesh.cc:2525"

set editor="/usr/bin/vim"
set header_cache="~/.neomutt/cache/"
set message_cachedir="~/.neomutt/cache/"
set pager_stop=yes
set sort=reverse-date
set sort_aux=last-date-received
set sidebar_format="%B%?F? [%F]?%* %?N?%N/?%S"
mailboxes =INBOX =[Gmail]/All\ Mail =[Gmail]/Sent\ Mail =[Gmail]/Drafts =[Gmail]/Spam =[Gmail]/Bin
unset delete
set include=yes
set query_command="mutt_vc_query -f ~/main.syncthing/wallflower/person/person.vcf '%s'"
set signature="~/main.syncthing/monochrome/module/neomutt/.signature"
set mail_check=30

bind editor <Tab> complete-query
bind editor ^T complete
bind index N search-opposite
bind index \CN toggle-new
bind index,pager R group-reply

# Probably just use `d` for fast archive, then `$` to sync.
bind index,pager x noop
macro index,pager xb "<save-message>=[Gmail]/Bin<enter><enter>"
macro index,pager xa "<save-message>=[Gmail]/All^V Mail<enter><enter>"
macro index,pager xi "<save-message>=INBOX<enter><enter>"
