# Customizations.
allow-hotplug enp34s0
auto enp34s0
iface enp34s0 inet dhcp

auto vmbr0
iface vmbr0 inet static
	address 10.8.40.1/24
	bridge-ports none
	bridge-stp off
	bridge-fd 0
	post-up echo 1 > /proc/sys/net/ipv4/ip_forward
	post-up iptables -t nat -A POSTROUTING -s '10.8.40.0/24' -o enp34s0 -j MASQUERADE
	post-down iptables -t nat -D POSTROUTING -s '10.8.40.0/24' -o enp34s0 -j MASQUERADE
	post-up iptables -t raw -I PREROUTING -i fwbr+ -j CT --zone 1
	post-down iptables -t raw -D PREROUTING -i fwbr+ -j CT --zone 1


source /etc/network/interfaces.d/*
